# PVARA Frontend Environment Variables
# Copy this file to .env and update values as needed

# Backend API URL
# Use the backend origin only; do not include a trailing /api suffix.
# For local development: http://localhost:6080
# For production: https://your-backend-url.com
REACT_APP_API_URL=http://localhost:6080

# Optional: Cloudflare Turnstile site key for candidate-facing verification
# When set, CV extraction and final application submit require a Turnstile token.
REACT_APP_TURNSTILE_SITE_KEY=

# Frontend port (optional, defaults to 3000)
PORT=3000

# ===== FOR TUNNEL DEPLOYMENT (ngrok/cloudflare) =====
# When using ngrok for backend, update REACT_APP_API_URL to your ngrok URL
# Example: REACT_APP_API_URL=https://your-subdomain.ngrok-free.dev
